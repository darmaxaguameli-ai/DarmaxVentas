{
  "version": 2,
  "functions": {
    "api/*.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/pdfs/(.*)", "destination": "/pdfs/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
