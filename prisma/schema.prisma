// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================================================================
// ENUMS - Para valores predefinidos y fijos
// =====================================================================

enum UserRole {
  ADMIN
  VENDEDOR
  REPARTIDOR
  CLIENTE
}

enum PedidoStatus {
  PENDIENTE
  EN_PROCESO
  EN_RUTA
  ENTREGADO
  CANCELADO
}

enum PaymentStatus {
  PAGADO
  NO_PAGADO
}

enum EstadoSesionCaja {
  ABIERTA
  CERRADA
}

enum TipoTransaccionCaja {
  INGRESO
  RETIRO
  VENTA
  CAMBIO
}

enum DeliverySpeed {
  ESTANDAR
  EXPRES
}


// =====================================================================
// MODELOS DE CONFIGURACIÓN DEL NEGOCIO
// =====================================================================

// Tipos de agua que ofreces (Premium, Alcalina, etc.)
model WaterType {
  id       String         @id @default(cuid())
  name     String         @unique
  services ServicePrice[]
}

// Precios de los servicios (recargas, tarifas, etc.)
model ServicePrice {
  id     String @id @default(cuid())
  name   String // "Recarga", "Tarifa de Recolección"
  method String // "Domicilio", "Mostrador"
  price  Float

  // Relaciones opcionales
  waterType   WaterType? @relation(fields: [waterTypeId], references: [id])
  waterTypeId String?

  jugBrands JugBrand[] // Relación muchos a muchos

  itemsPedido PedidoItem[]

  // Un precio de servicio debe ser único para la combinación de sus propiedades
  @@unique([name, method, waterTypeId])
}

// Marcas de garrafones que manejas (Bonafont, Ciel, etc.)
model JugBrand {
  id   String @id @default(cuid())
  name String @unique

  // Relación con la tapa compatible en el inventario
  compatibleCap   Product? @relation(fields: [compatibleCapId], references: [id])
  compatibleCapId String?
  
  servicePrices ServicePrice[] // Relación muchos a muchos
}

// =====================================================================
// MODELOS DE FRANQUICIA Y SUCURSALES (¡NUEVOS!)
// =====================================================================

// 1. La Franquicia (El dueño de varias purificadoras)
model Franchise {
  id        String   @id @default(cuid())
  name      String   @unique
  stores    Store[]
  createdAt DateTime @default(now())
}

// 2. La Sucursal (Cada punto de venta físico)
model Store {
  id           String        @id @default(cuid())
  name         String
  address      String
  latitud      Float?        // Para que el cliente encuentre la más cercana
  longitud     Float?
  franchise    Franchise     @relation(fields: [franchiseId], references: [id])
  franchiseId  String
  
  // Relaciones
  users        User[]
  pedidos      Pedido[]
  sesionesCaja SesionCaja[]
  inventory    StoreInventory[] // El stock ahora es por sucursal
}

// 3. Inventario por Sucursal
model StoreInventory {
  id        String   @id @default(cuid())
  store     Store    @relation(fields: [storeId], references: [id])
  storeId   String
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  stock     Int      @default(0)

  @@unique([storeId, productId]) // Una sucursal solo tiene una entrada por producto
}


// =====================================================================
// MODELOS PRINCIPALES (MODIFICADOS)
// =====================================================================

model User {
  id                 String            @id @default(cuid())
  customId           String            @unique // ID legible para humanos, ej: CL-0001
  name               String
  email              String?           @unique
  password           String?
  phone              String?           @unique
  street             String?
  neighborhood       String?
  city               String?
  postalCode         String?
  references         String?
  lat                Float?
  lng                Float?
  role               UserRole          @default(CLIENTE)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  
  // Relaciones
  pedidos            Pedido[]
  sesionesCaja       SesionCaja[]
  empleado           Empleado?
  
  // Nueva relación con Sucursal (Opcional, pues un cliente puede no tener una fija)
  store              Store?            @relation(fields: [storeId], references: [id])
  storeId            String?

  // Relación inversa para pedidos asignados como repartidor
  pedidosReparto     Pedido[]          @relation("RepartidorPedidos")
}

// Renombrado de "Producto" a "Product" para seguir convenciones.
model Product {
  id          String       @id @default(cuid())
  name        String       @unique
  // Precio de VENTA del artículo físico (ej: garrafón vacío)
  price       Float
  stock       Int          @default(0) // Stock global o legacy
  imageUrl    String?
  // Categorías como: "Garrafones Vacíos", "Tapas"
  category    String?
  itemsPedido PedidoItem[]

  // Relación inversa para las tapas
  jugBrandsAsCap JugBrand[]

  // Relación con inventarios de sucursal
  storeInventories StoreInventory[]
}

model Pedido {
  id                  String           @id @default(cuid())
  customId            String           @unique // Ej: ORD-0001
  total               Float
  status              PedidoStatus     @default(PENDIENTE)
  deliveryMethod      String // ej: "domicilio", "recoleccion", "sucursal"
  paymentMethod       String? // ej: "efectivo", "tarjeta"
  paymentStatus       PaymentStatus    @default(NO_PAGADO)
  deliveryDate        DateTime? // Fecha de entrega preferida
  deliveryTimeSlot    String? // Franja horaria de entrega preferida (ej: "9am-12pm")
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  // Relaciones existentes
  cliente             User             @relation(fields: [clienteId], references: [id])
  clienteId           String
  items               PedidoItem[]
  sesionCaja          SesionCaja?      @relation(fields: [sesionCajaId], references: [id])
  sesionCajaId        String?
  ingreso             Ingreso?         @relation("PedidoToIngreso")
  transaccionCaja     TransaccionCaja?

  // --- NUEVOS CAMPOS DE LOGÍSTICA ---
  deliverySpeed    DeliverySpeed @default(ESTANDAR)
  expressSurcharge Float         @default(0.0)
  deliveryLat      Float?
  deliveryLng      Float?
  
  // Relación con el repartidor
  repartidor       User?         @relation("RepartidorPedidos", fields: [repartidorId], references: [id])
  repartidorId     String?

  // Relación con la sucursal (Requerido para saber quién atiende)
  store            Store         @relation(fields: [storeId], references: [id])
  storeId          String
}

// Modificado para poder registrar la venta de un Producto físico o un Servicio
model PedidoItem {
  id       String @id @default(cuid())
  quantity Int
  price    Float // Precio del producto/servicio en el momento de la compra

  pedido   Pedido @relation(fields: [pedidoId], references: [id])
  pedidoId String

  // Un item del pedido puede ser UN producto físico O UN servicio de precio
  product        Product?      @relation(fields: [productId], references: [id])
  productId      String?
  servicePrice   ServicePrice? @relation(fields: [servicePriceId], references: [id])
  servicePriceId String?

  // Campos para almacenar la información específica del garrafón
  jugBrandId       String?
  jugBrandName     String?
  jugBrandImageUrl String?
}

// =====================================================================
// MODELOS PARA EL DASHBOARD DE GESTIÓN
// =====================================================================

model SesionCaja {
  id              String           @id @default(cuid())
  startedAt       DateTime         @default(now())
  endedAt         DateTime?
  openingBalance  Float
  closingBalance  Float?
  expectedBalance Float?
  estado          EstadoSesionCaja @default(ABIERTA)
  
  vendedor        User             @relation(fields: [vendedorId], references: [id])
  vendedorId      String
  
  // Relación con la sucursal (Requerido)
  store           Store            @relation(fields: [storeId], references: [id])
  storeId         String

  transacciones   TransaccionCaja[]
  pedidos         Pedido[]
}

model TransaccionCaja {
  id          String            @id @default(cuid())
  tipo        TipoTransaccionCaja
  amount      Float
  description String?
  createdAt   DateTime          @default(now())
  sesion      SesionCaja        @relation(fields: [sesionId], references: [id])
  sesionId    String
  pedido      Pedido?           @relation(fields: [pedidoId], references: [id])
  pedidoId    String?           @unique
}

model Gasto {
  id          String   @id @default(cuid())
  description String
  amount      Float
  date        DateTime
}

model Ingreso {
  id                 String            @id @default(cuid())
  description        String
  amount             Float
  date               DateTime
  pedido             Pedido?           @relation("PedidoToIngreso", fields: [pedidoId], references: [id])
  pedidoId           String?           @unique
  dailySalesRecord   DailySalesRecord? @relation("DailySalesRecordToIngreso", fields: [dailySalesRecordId], references: [id])
  dailySalesRecordId String?           @unique
}

model DailySalesRecord {
  id                       String   @id @default(cuid())
  date                     DateTime @unique
  dayOfWeek                String
  mostradorColor           Int      @default(0)
  mostradorBon             Int      @default(0)
  mostradorEpura           Int      @default(0)
  mostradorCiel            Int      @default(0)
  mostradorElectro         Int      @default(0)
  mostrador10Lts           Int      @default(0)
  mostradorVtaG            Int      @default(0)
  mostradorTotal           Float    @default(0)
  pedidosColor             Int      @default(0)
  pedidosBon               Int      @default(0)
  pedidosEpura             Int      @default(0)
  pedidosCiel              Int      @default(0)
  pedidosElectro           Int      @default(0)
  pedidos10Lts             Int      @default(0)
  pedidosVtaG              Int      @default(0)
  pedidosTotal             Float    @default(0)
  negociosColor            Int      @default(0)
  negociosBon              Int      @default(0)
  negociosEpura            Int      @default(0)
  negociosCiel             Int      @default(0)
  negociosElectro          Int      @default(0)
  negocios10Lts            Int      @default(0)
  negociosVtaG             Int      @default(0)
  negociosTotal            Float    @default(0)
  totalTipoGarrafonColor   Int      @default(0)
  totalTipoGarrafonBon     Int      @default(0)
  totalTipoGarrafonEpura   Int      @default(0)
  totalTipoGarrafonCiel    Int      @default(0)
  totalTipoGarrafonElectro Int      @default(0)
  totalTipoGarrafon10Lts   Int      @default(0)
  totalTipoGarrafonVtaG    Int      @default(0)
  totalGarrafones          Int      @default(0)
  totalImporte             Float    @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  ingreso                  Ingreso? @relation("DailySalesRecordToIngreso")
}

// =====================================================================
// MODELOS PARA EL MÓDULO DE RECURSOS HUMANOS (RRHH)
// =====================================================================

enum EstatusEmpleado {
  ACTIVO
  INACTIVO
}

enum TipoTerminacion {
  RENUNCIA
  DESPIDO
  LIQUIDACION
}

enum TipoDocumento {
  INE
  CONTRATO
  COMPROBANTE_DOMICILIO
  OTRO
}

model Empleado {
  id             String @id @default(cuid())
  nombreCompleto String
  puesto         String
  sueldo         Float // Sueldo actual

  // Información de contacto y dirección
  telefono      String?
  emailPersonal String? @unique
  street        String?
  neighborhood  String?
  city          String?
  postalCode    String?

  // Fechas y estatus de RRHH
  fechaContratacion DateTime
  fechaTerminacion  DateTime?
  tipoTerminacion   TipoTerminacion?
  estatus           EstatusEmpleado  @default(ACTIVO)

  // Relación con la tabla de autenticación (User)
  // Un registro de empleado puede estar asociado con una cuenta de usuario
  user   User?   @relation(fields: [userId], references: [id])
  userId String? @unique

  // Relación para el organigrama (auto-referencial)
  manager      Empleado?  @relation("DirectReports", fields: [managerId], references: [id])
  managerId    String?
  subordinados Empleado[] @relation("DirectReports")

  // Relación con sus documentos y historial de sueldos
  documentos       Documento[]
  historialSueldos HistorialSueldo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Documento {
  id        String        @id @default(cuid())
  nombre    String // Ej: "Contrato Laboral", "INE Frente"
  url       String // URL del archivo almacenado (ej: en S3, Cloudinary, etc.)
  tipo      TipoDocumento // Usar el enum
  createdAt DateTime      @default(now())

  // Relación con el empleado
  empleado   Empleado @relation(fields: [empleadoId], references: [id])
  empleadoId String
}

model HistorialSueldo {
  id          String    @id @default(cuid())
  empleado    Empleado  @relation(fields: [empleadoId], references: [id])
  empleadoId  String
  sueldo      Float
  fechaInicio DateTime
  fechaFin    DateTime? // Opcional, si hay una fecha de finalización para este sueldo
  motivo      String? // Ej: "Aumento por desempeño", "Ajuste anual"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}