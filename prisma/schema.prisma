// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
/* ===========================
   ENUMS NUEVOS (AGUA / ENTREGA)
   =========================== */

enum TipoPedido {           // NEW
  RELLENO                  // Flujo de "Rellenar garrafón"
  COMPRA_GARRAFON          // Flujo de "Comprar garrafón"
}

enum MetodoEntrega {        // NEW
  DOMICILIO                // Entrega a domicilio
  RECOLECCION              // Recolección en casa + entrega
  SUCURSAL                 // Recoger en sucursal / mostrador
}

enum TipoAgua {             // NEW
  PURIFICADA
  PREMIUM
  ALCALINA
  SALES
}

/* ===========================
   MODELOS DE USUARIOS
   =========================== */

// Cliente final
model User {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  email        String   @unique
  name         String?
  telefono     String?
  passwordHash String?  // Nullable para invitados / generados por admin

  // Dirección principal (puedes luego mover a un modelo Address si quieres varias)
  calle        String?
  colonia      String?
  codigoPostal String?
  ciudad       String?
  estadoEnvio  String?
  pais         String?

  // Relación con Pedidos y Carrito
  pedidos      Pedido[]
  carritoItems CarritoItem[]
}

// Admin del panel
model AdminUser {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  email        String   @unique
  name         String
  passwordHash String
}

/* ===========================
   MODELOS DE PRODUCTOS
   =========================== */

model Categoria {
  id        Int        @id @default(autoincrement())
  nombre    String     @unique
  productos Producto[]
}

model Producto {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  nombre      String
  precio      Float
  descripcion String?
  stock       Int      @default(0)
  imagen      String?

  // Campos para envío (si se requieren)
  pesoKg      Float?
  largoCm     Float?
  anchoCm     Float?
  altoCm      Float?

  // Relación con Categoria
  categoriaId Int
  categoria   Categoria @relation(fields: [categoriaId], references: [id])

  // Relación con Pedidos y Carrito
  pedidos      PedidosEnProductos[]
  carritoItems CarritoItem[]
}

/* ===========================
   MODELOS DE PEDIDOS
   =========================== */

enum EstadoPedido {
  PENDIENTE
  PAGADO
  ENVIADO
  ENTREGADO
  CANCELADO
}

model Pedido {
  id         Int          @id @default(autoincrement())
  createdAt  DateTime     @default(now())
  orden      String       @unique @default(cuid())
  total      Float
  estado     EstadoPedido @default(PENDIENTE)

  // NEW: tipo de flujo (relleno / compra de garrafón)
  tipoPedido     TipoPedido

  // NEW: método de entrega seleccionado en Paso 3
  metodoEntrega  MetodoEntrega

  // NEW: opcionalmente, fecha/hora programada de entrega o recolección
  fechaProgramada DateTime?

  // Datos del cliente (snapshot en el pedido)
  clienteNombre   String
  clienteEmail    String
  clienteTelefono String?

  // Dirección de envío (ahora opcionales porque en sucursal no aplica)
  direccion       String?
  ciudad          String?
  estadoEnvio     String?
  codigoPostal    String?

  // Relación con User (opcional para invitados)
  userId    Int?
  user      User?        @relation(fields: [userId], references: [id])

  // Relación con Productos (líneas de productos)
  productos PedidosEnProductos[]

  // NEW: Detalle específico de garrafones seleccionados
  garrafones PedidoGarrafonDetalle[]

  // NEW: Detalle de tipos de agua asignados
  tiposAgua PedidoTipoAgua[]
}

/* Relación muchos-a-muchos Pedido <-> Producto (genérico) */
model PedidosEnProductos {
  pedido     Pedido   @relation(fields: [pedidoId], references: [id])
  pedidoId   Int
  producto   Producto @relation(fields: [productoId], references: [id])
  productoId Int
  cantidad   Int

  // Guardar precio de la compra
  precioAlComprar Float

  @@id([pedidoId, productoId])
}

/* ===========================
   NEW: DETALLE DE GARRAFONES POR PEDIDO
   =========================== */

model PedidoGarrafonDetalle {     // NEW
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  pedidoId  Int
  pedido    Pedido   @relation(fields: [pedidoId], references: [id])

  // Ejemplo: "Garrafón Darmax 20L", "Garrafón 10L", etc.
  // Puedes mapear estas opciones desde el front.
  descripcion   String          // Nombre amigable que ves en el paso 1
  capacidadLitros Int           // 20, 10, etc.
  marca         String?         // "Darmax", "Ciel", "Epura", etc.

  cantidad      Int
}

/* ===========================
   NEW: DETALLE DE TIPOS DE AGUA POR PEDIDO
   =========================== */

model PedidoTipoAgua {             // NEW
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  pedidoId  Int
  pedido    Pedido   @relation(fields: [pedidoId], references: [id])

  tipoAgua  TipoAgua       // PREMIUM, ALCALINA, etc.
  cantidad  Int            // Cuántos garrafones de ese tipo
}

/* ===========================
   MODELO CARRITO
   =========================== */

model CarritoItem {
  id         Int      @id @default(autoincrement())
  cantidad   Int
  createdAt  DateTime @default(now())

  // Usuario dueño de este ítem
  userId     Int
  user       User     @relation(fields: [userId], references: [id])

  // Producto
  productoId Int
  producto   Producto @relation(fields: [productoId], references: [id])

  // Un usuario solo puede tener un renglón por producto
  @@unique([userId, productoId])
}
