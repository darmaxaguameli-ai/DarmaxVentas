// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
// --------------------------------------------------
// ENUMS - Para valores predefinidos
// --------------------------------------------------

enum UserRole {
  ADMIN
  VENDEDOR
  REPARTIDOR
  CLIENTE
}

enum PedidoStatus {
  PENDIENTE
  EN_PROCESO
  EN_RUTA
  ENTREGADO
  CANCELADO
}

enum PaymentStatus {
  PAGADO
  NO_PAGADO
}


// --------------------------------------------------
// MODELOS PRINCIPALES
// --------------------------------------------------

model User {
  id        String   @id @default(cuid())
  customId  String   @unique // ID legible para humanos, ej: CL-0001
  name      String
  
  // --- Campos para "Cuenta Completa" ---
  email     String?  @unique // Opcional: solo para cuentas con login
  password  String?           // Opcional: solo para cuentas con login
  
  // --- Campos de Contacto y Dirección ---
  phone     String?  @unique // Opcional, pero útil para buscar clientes
  street         String?
  neighborhood   String?
  city           String?
  postalCode     String?
  references     String?

  role      UserRole @default(CLIENTE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- Relaciones ---
  pedidos     Pedido[]
  sesionesCaja SesionCaja[]
}

model Producto {
  id         String   @id @default(cuid())
  name       String
  price      Float
  stock      Int      @default(0) // Para el módulo de Inventario
  imageUrl   String?
  category   String?

  // --- Relaciones ---
  itemsPedido PedidoItem[]
}


model Pedido {
  id        String   @id @default(cuid())
  customId  String   @unique // Ej: ORD-0001
  total     Float
  status    PedidoStatus @default(PENDIENTE)
  deliveryMethod String // ej: "domicilio", "recoleccion", "sucursal"
  paymentMethod String? // ej: "efectivo", "tarjeta"
  paymentStatus PaymentStatus @default(NO_PAGADO)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- Relaciones ---
  cliente     User         @relation(fields: [clienteId], references: [id])
  clienteId   String

  items       PedidoItem[]

  sesionCaja  SesionCaja?  @relation(fields: [sesionCajaId], references: [id])
  sesionCajaId String?

  ingreso     Ingreso?
}

// Tabla intermedia para la relación muchos-a-muchos entre Pedido y Producto
model PedidoItem {
  id         String   @id @default(cuid())
  quantity   Int
  price      Float    // Precio del producto en el momento de la compra

  // --- Relaciones ---
  pedido     Pedido   @relation(fields: [pedidoId], references: [id])
  pedidoId   String

  producto   Producto @relation(fields: [productoId], references: [id])
  productoId String

  @@unique([pedidoId, productoId])
}


// --------------------------------------------------
// MODELOS PARA EL DASHBOARD DE GESTIÓN
// --------------------------------------------------

model SesionCaja {
  id              String   @id @default(cuid())
  startedAt       DateTime @default(now())
  endedAt         DateTime?
  openingBalance  Float    // Saldo inicial
  closingBalance  Float?   // Saldo al cerrar
  expectedBalance Float?   // Calculado = inicial + ventas - retiros + ingresos

  // --- Relaciones ---
  vendedor        User     @relation(fields: [vendedorId], references: [id])
  vendedorId      String

  transacciones   Transaccion[]
  pedidos         Pedido[]
}

model Transaccion {
  id          String   @id @default(cuid())
  type        String   // "INGRESO_CAJA", "RETIRO_CAJA", "VENTA"
  amount      Float
  description String?
  
  createdAt   DateTime @default(now())

  // --- Relaciones ---
  sesion      SesionCaja @relation(fields: [sesionId], references: [id])
  sesionId    String
}


model Gasto {
  id          String   @id @default(cuid())
  description String
  amount      Float
  date        DateTime
}


model Ingreso {
  id          String   @id @default(cuid())
  description String
  amount      Float
  date        DateTime

  // --- Relaciones ---
  // Un ingreso puede estar asociado a un pedido específico
  pedido      Pedido?   @relation(fields: [pedidoId], references: [id])
  pedidoId    String?   @unique
}